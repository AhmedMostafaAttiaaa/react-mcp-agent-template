# Ollama host — used for generation when provider: ollama, and always for RAG embeddings
# regardless of which generation provider is active (Groq is generation-only).
OLLAMA_HOST=http://localhost:11434

# Required for the committed default, provider: groq, in config.yaml.
# Get a free key at https://console.groq.com/keys
# Leave blank and set provider: ollama in config.yaml instead for fully offline use with
# zero API keys and zero network calls outside your own Ollama host (embeddings still need
# a reachable Ollama host either way).
GROQ_API_KEY=
