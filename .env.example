# Ollama host used for generation (when provider: ollama) and always for embeddings.
OLLAMA_HOST=http://localhost:11434

# Optional. Only required if config.yaml sets `provider: groq`.
# With provider: ollama (the default), this project needs zero API keys and makes
# zero network calls outside your own Ollama host.
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
